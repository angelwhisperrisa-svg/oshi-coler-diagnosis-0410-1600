# Vercel Environment Variables（Production / Preview に設定）
# Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
# Webhook 署名検証（api/line/webhook.js）
LINE_CHANNEL_SECRET=
# LIFF の ID トークン検証用（LINE Developers の「チャネルID」数値。LIFF ID とは別）
LINE_CHANNEL_ID=
# Push 文面に載せる本番サイトのオリジン（末尾スラッシュなし）
PUBLIC_SITE_URL=https://shima-brand.vercel.app

# フロント（ビルド時に埋め込み）— LINE Developers で作成した LIFF アプリの ID
# LIFF のスコープに openid / profile に加え「友だち関係（friendship）」を必ず ON
REACT_APP_LIFF_ID=

# 公式LINEのQR画像URL（任意。未設定時は友だち追加URLから自動生成QRを表示）
REACT_APP_LINE_QR_IMAGE_URL=

# 各色のBASEショップURL（任意。未設定時は REACT_APP_BASE_FULL_URL またはデフォルト）
REACT_APP_BASE_MINT=
REACT_APP_BASE_ROSE=
REACT_APP_BASE_LAVENDER=
REACT_APP_BASE_IVORY=
REACT_APP_BASE_SKYBLUE=
REACT_APP_BASE_FULL_URL=

# ローカル開発のみ：1 にすると LINE ゲートをスキップ（本番では設定しない）
REACT_APP_DEV_LINE_BYPASS=
