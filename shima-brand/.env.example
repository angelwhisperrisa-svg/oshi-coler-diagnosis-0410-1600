# Vercel Environment Variables（Production / Preview に設定）
# Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
# Webhook 署名検証（api/line/webhook.js）
LINE_CHANNEL_SECRET=
# LIFF の ID トークン検証用（LINE Developers の「チャネルID」数値。LIFF ID とは別）
LINE_CHANNEL_ID=
# Push 文面に載せる本番サイトのオリジン（末尾スラッシュなし）
PUBLIC_SITE_URL=https://shima-brand.vercel.app

# フロント（ビルド時に埋め込み）— LINE Developers で作成した LIFF アプリの ID
REACT_APP_LIFF_ID=
